{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "mermaid": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-mermaid"]
    },
    "excalidraw": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "excalidraw-mcp"]
    }
  }
}
